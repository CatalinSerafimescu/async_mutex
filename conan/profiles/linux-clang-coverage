# Conan profile: linux-clang-coverage

[settings]
os=Linux
arch=x86_64
build_type=Debug
compiler=clang
compiler.version=22
compiler.libcxx=libstdc++11
compiler.cppstd=23

[buildenv]
CC=clang-22
CXX=clang++-22
CXXFLAGS=-fprofile-instr-generate -fcoverage-mapping
LDFLAGS=-fprofile-instr-generate
LLVM_PROFILE_FILE=%m_%p.profraw

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
tools.build:cxxflags=["-fprofile-instr-generate", "-fcoverage-mapping"]
tools.build:exelinkflags=["-fprofile-instr-generate"]
tools.info.package_id:confs=["tools.build:cxxflags", "tools.build:cflags", "tools.build:sharedlinkflags", "tools.build:exelinkflags"]
